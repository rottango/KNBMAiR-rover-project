    </xacro:macro>
    
    <!-- AKUMULATOR LITOWO-JONOWY 24V 10..0AH LIFEPO4 WYSOKA WYDAJNOŚĆ,DŁUGA ŻYWOTNOŚĆ -->
    <xacro:macro name="Battery_pos">
