<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Raspberry Pi Active Cooler - aktywne chłodzenie - radiator + wentylator do Raspberry Pi 5 -->
    <xacro:macro name="Active_Cooler_pos">
        <xacro:property name="pos_x" value="0.0" scope="parent" />
        <xacro:property name="pos_y" value="0.0" scope="parent" />
        <xacro:property name="pos_z" value="0.0" scope="parent" />
        <xacro:property name="pos_r" value="0.0" scope="parent" />
        <xacro:property name="pos_p" value="0.0" scope="parent" />
        <xacro:property name="pos_yy" value="0.0" scope="parent" />
    </xacro:macro>
    <!-- Ubiquiti AirMax Sector  -->
    <xacro:macro name="AirMax_Sector_pos">
        <xacro:property name="pos_x" value="1.0" scope="parent" />
        <xacro:property name="pos_y" value="0.0" scope="parent" />
        <xacro:property name="pos_z" value="0.0" scope="parent" />
